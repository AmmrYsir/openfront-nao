# OpenFront NAO local environment template
# Copy this file to .env (or run: npm run env:init)

# Backend HTTP
API_HOST=0.0.0.0
API_PORT=8787
API_CORS_ORIGIN=*
API_PUBLIC_BASE=http://localhost:8787

# Backend auth/service key
# Replace in non-local environments.
API_KEY=dev-api-key

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/openfront_nao
DATABASE_SSL=false

# Optional frontend runtime overrides (query/localStorage still supported)
# VITE_API_DOMAIN_OVERRIDE=
# VITE_LOCAL_API_HOST=http://localhost:8787

# Optional live transport debug values
# LIVE_WS_URL=
# LIVE_GAME_ID=
# LIVE_WS_PROTOCOL=legacy
