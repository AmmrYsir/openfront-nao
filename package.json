{
  "name": "openfront-nao",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend:dev": "bun run src/backend/server.ts",
    "db:migrate": "bun run src/backend/db/migrate.ts",
    "env:init": "node scripts/init-env.mjs",
    "env:check": "node scripts/validate-env.mjs",
    "gap:report": "node scripts/gap-report.mjs",
    "classic:build": "node scripts/build-classic-compat.mjs",
    "classic:test": "node scripts/classic-test.mjs",
    "check:legacy-deps": "node scripts/check-old-project-imports.mjs",
    "test": "bun test ./tests",
    "test:all": "npm run test && npm run classic:test",
    "build": "bun run check:legacy-deps && tsc && vite build",
    "build:all": "npm run build && npm run classic:build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/seedrandom": "^3.0.8",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "pg": "^8.20.0",
    "seedrandom": "^3.0.5",
    "zod": "^4.3.6"
  }
}
